.contenedor {
  position: relative;
  width: 500px;
  height: 300px;
  background-color: #ccc;
  margin: auto;
}

.uno {
  position: absolute;
  top: 20px;
  left: 120px;
  width: 250px;
  height: 150px;
  background-color: blue;
  font-size: 50px;
  z-index: 1;
}

.dos {
  position: absolute;
  top: 120px;
  left: 40px;
  width: 180px;
  height: 140px;
  background-color: green;
  font-size: 50px;
  z-index: 0;
}

.tres {
  position: absolute;
  top: 80px;
  right: 40px;
  width: 220px;
  height: 160px;
  background-color: yellow;
  font-size: 50px;
  z-index: 2;
}

.cuatro {
  position: absolute;
  bottom: 20px;
  left: 150px;
  width: 260px;
  height: 120px;
  background-color: red;
  font-size: 50px;
  z-index: 3;
}
